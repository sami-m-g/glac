{
  "name": "glac",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun adk web",
    "lint": "bunx @biomejs/biome lint . --write",
    "fmt": "bunx @biomejs/biome format . --write",
    "check": "bunx @biomejs/biome check . --write",
    "tc": "tsc -p tsconfig.json --noEmit",
    "fc": "bun run check && bun run tc",
    "pre": "pre-commit run --all-files"
  },
  "devDependencies": {
    "@google/adk-devtools": "^0.4.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/adk": "^0.4.0",
    "@google/genai": "^1.43.0",
    "zod": "^4.3.6"
  }
}
